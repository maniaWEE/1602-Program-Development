#include "imgui.h"
#include "implot.h"
#include "imgui_impl_glfw.h"
#include "imgui_impl_opengl3.h"
#include <GLFW/glfw3.h>

void RenderGrid(int size = 100)
{
    if (ImPlot::BeginPlot("XY Grid"))
    {
        ImPlot::SetupAxes("X", "Y");

        // Fix limits to 0 → size
        ImPlot::SetupAxesLimits(0, size, 0, size, ImGuiCond_Always);

        // Optional: force 1-unit grid ticks
        ImPlot::SetupAxisTicks(ImAxis_X1, 0, size, size + 1);
        ImPlot::SetupAxisTicks(ImAxis_Y1, 0, size, size + 1);

        ImPlot::EndPlot();
    }
}

ImGui::Begin("Plot Window");

RenderGrid(100);  // 🔥 ONE LINE

ImGui::End();
